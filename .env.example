# =========================
# FastAPI 应用基础配置
# =========================
APP_NAME=LoveGuruAgent
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=9000
APP_DEBUG=true

# =========================
# PostgreSQL / pgvector 配置
# 按你的真实数据库账号密码修改
# =========================
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/love_guru
DATABASE_ECHO=false

# =========================
# 模型供应商选择
# 可选: qwen / openai
# =========================
LLM_PROVIDER=qwen

# =========================
# OpenAI 配置
# 当前 settings.py 要求这些字段必须存在
# 即使暂时不用 OpenAI，也先保留占位值
# =========================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# =========================
# 阿里千问 / DashScope 配置
# 当前 settings.py 要求这些字段必须存在
# 即使暂时不用千问，也先保留占位值
# =========================
DASHSCOPE_API_KEY=your_dashscope_api_key
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4

# =========================
# 向量库 / 知识库 / 日志配置
# VECTOR_DIMENSION 必须和实际 embedding 模型输出维度一致
# =========================
VECTOR_DIMENSION=1024
KNOWLEDGE_DOCS_DIR=docs
LOG_LEVEL=INFO
