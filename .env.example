# =========================
# FastAPI 应用基础配置
# =========================
APP_NAME=LoveGuruAgent
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=9000
APP_DEBUG=true

# =========================
# PostgreSQL / pgvector 配置
# 按你的真实数据库账号密码修改
# =========================
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/love_guru
DATABASE_ECHO=false

# =========================
# 模型供应商选择
# 可选: qwen / openai
# =========================
LLM_PROVIDER=qwen

# =========================
# OpenAI 配置
# 当前 settings.py 要求这些字段必须存在
# 即使暂时不用 OpenAI，也先保留占位值
# =========================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# =========================
# 阿里千问 / DashScope 配置
# 当前 settings.py 要求这些字段必须存在
# 即使暂时不用千问，也先保留占位值
# =========================
DASHSCOPE_API_KEY=your_dashscope_api_key
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4

# =========================
# 向量库 / 知识库 / 日志配置
# VECTOR_DIMENSION 必须和实际 embedding 模型输出维度一致
# =========================
VECTOR_DIMENSION=1024
KNOWLEDGE_DOCS_DIR=docs
LOG_LEVEL=INFO

# =========================
# 百度地图 API 配置
# 用于地点搜索功能(餐厅、ATM等)
# =========================
BAIDU_MAP_AK=your_baidu_map_ak

# =========================
# LangSmith 相关配置（暂不使用，保留供后续自建 DevOps 时参考）
# =========================
#LANGCHAIN_TRACING_V2=false
#LANGCHAIN_API_KEY=lsv2_your_key_here
LANGCHAIN_PROJECT=LoveGuruAgent

# =========================
# LangGraph 持久执行配置（Checkpointer）
# 用于实现断点续传和状态持久化
# CHECKPOINTER_URI 默认复用 DATABASE_URL
# ENABLE_CHECKPOINTER=false 时使用内存存储（不持久化）
# =========================
CHECKPOINTER_URI=postgresql://postgres:your_password@localhost:5432/love-guru-agent?client_encoding=utf8
ENABLE_CHECKPOINTER=true

# =========================
# LangGraph 人工参与配置（Human-in-the-loop）
# 敏感词检测，命中后暂停等待人工审批
# ENABLE_SENSITIVE_FILTER=false 时不启用敏感词过滤
# SENSITIVE_KEYWORDS 可选自定义敏感词列表（逗号分隔）
# =========================
ENABLE_SENSITIVE_FILTER=true
#SENSITIVE_KEYWORDS=自杀,自残,暴力

# =========================
# LangGraph 全面记忆配置（Comprehensive Memory）
# 跨会话长期记忆存储和检索
# ENABLE_LONG_MEMORY=false 时不启用长期记忆
# LONG_MEMORY_MAX_ENTRIES 每用户最多记忆数（超出自动淘汰）
# =========================
ENABLE_LONG_MEMORY=true
LONG_MEMORY_MAX_ENTRIES=100

# =========================
# 可观测性配置（性能追踪与 debug）
# 使用项目内置日志系统替代 LangSmith
# =========================
ENABLE_OBSERVABILITY=true
OBSERVABILITY_LOG_LEVEL=info
